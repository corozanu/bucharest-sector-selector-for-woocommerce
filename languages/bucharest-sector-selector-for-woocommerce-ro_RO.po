msgstr "Sector 6"

#: includes/class-bsswoo-helpers.php
msgid "Pentru adresa de facturare din București, selectați sectorul."
msgstr "Pentru adresa de facturare din București, selectați sectorul."

#: includes/class-bsswoo-helpers.php
msgid "Pentru adresa de livrare din București, selectați sectorul."
