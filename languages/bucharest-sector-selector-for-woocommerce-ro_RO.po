#: bucharest-sector-selector-for-woocommerce.php
msgid "Bucharest Sector Selector for WooCommerce requires WooCommerce to be installed and active."
msgstr "Bucharest Sector Selector for WooCommerce necesită WooCommerce instalat și activ."

#: includes/class-bsswoo-admin-order.php
#: includes/class-bsswoo-blocks-fields.php
#: includes/class-bsswoo-helpers.php
msgid "Sector București"
msgstr "Sector București"

#: includes/class-bsswoo-admin-settings.php
msgid "eFactura Sector"
msgstr "eFactura Sector"

#: includes/class-bsswoo-admin-settings.php
msgid "Bucharest Sector Selector"
msgstr "Selector Sector București"

#: includes/class-bsswoo-admin-settings.php
msgid "Configure sector selection for Bucharest addresses to ensure SPV ANAF / e-Factura compatibility. Checkout Block support requires WooCommerce 8.9 or newer."
msgstr "Configurați selecția sectorului pentru adresele din București, pentru compatibilitate SPV ANAF / e-Factura. Suportul Checkout Block necesită WooCommerce 8.9 sau mai nou."

#: includes/class-bsswoo-admin-settings.php
msgid "Enable plugin logic"
msgstr "Activează logica pluginului"

#: includes/class-bsswoo-admin-settings.php
msgid "Enable Bucharest sector selection and city sync."
msgstr "Activează selecția sectorului București și sincronizarea orașului."

#: includes/class-bsswoo-admin-settings.php
msgid "Enable shipping address logic"
msgstr "Activează logica pentru adresa de livrare"

#: includes/class-bsswoo-admin-settings.php
msgid "Apply the same logic to the shipping address when it differs from billing."
msgstr "Aplică aceeași logică adresei de livrare când diferă de cea de facturare."

#: includes/class-bsswoo-admin-settings.php
msgid "Hide city field for Bucharest"
msgstr "Ascunde câmpul oraș pentru București"

#: includes/class-bsswoo-admin-settings.php
msgid "Hide the city/locality field when Bucharest is selected. Applies to classic checkout and Checkout Block."
msgstr "Ascunde câmpul oraș/localitate când este selectat București. Se aplică la checkout clasic și Checkout Block."

#: includes/class-bsswoo-admin-settings.php
msgid "Make city readonly instead of hidden"
msgstr "Fă câmpul oraș doar-citire în loc de ascuns"

#: includes/class-bsswoo-admin-settings.php
msgid "Only applies when the city field is not hidden. The city will be auto-filled with the selected sector in classic checkout and Checkout Block."
msgstr "Se aplică doar când câmpul oraș nu este ascuns. Orașul va fi completat automat cu sectorul selectat în checkout clasic și Checkout Block."

#: includes/class-bsswoo-admin-settings.php
msgid "Debug mode"
msgstr "Mod depanare"

#: includes/class-bsswoo-admin-settings.php
msgid "Log plugin events to WooCommerce logs (source: bsswoo)."
msgstr "Înregistrează evenimentele pluginului în jurnalele WooCommerce (sursă: bsswoo)."

#: includes/class-bsswoo-frontend-assets.php
#: includes/class-bsswoo-helpers.php
msgid "Selectează sectorul"
msgstr "Selectează sectorul"

